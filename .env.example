## GEMINI

# A valid Gemini API key is required to run the project's AI features.
# The key can be obtained either from Google Vertex AI or Google AI Studio.
# API usage may incur costs depending on your configuration and usage volume, so use it at your own financial risk.
# Make sure the key is kept private and never committed to the repository.
# The .gitignore file already includes rules to prevent accidental exposure.

GOOGLE_GENAI_API_KEY=
GEMINI_API_KEY=

## SUPABASE BUCKET

# Supabase is used by the bucket synchronization system.
# During development, it allowed the team to share generated assets without committing large or expensive files to the repository.
# This prevents the repo from becoming unnecessarily heavy and keeps version control clean.
# If you are running the project alone, this system is optional and can be safely ignored.

SUPABASE_URL=
SUPABASE_BUCKET=
SUPABASE_STORAGE_PREFIX=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_CHARACTER_BUCKET=public-assets

## GCP

# To use the music generation feature, a properly configured Google Cloud Platform project is required.
# The Vertex AI API must be enabled in the GCP project.
# A service account authentication JSON file must be placed at the root of the project.
# This file should be added to .gitignore if you plan to fork or commit the repository.

VERTEX_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_LOCATION=us-central1
VERTEX_LYRIA_MODEL=lyria-002

## DEMO

# Use pregenerated jobs during the demo to either test or replay features.
# Set DEMO_STEP_ONE_PREREGENERATED=true to enable pregenerated jobs.
# Set DEMO_STEP_ONE_PREREGENERATED=false to disable pregenerated jobs.
# Choose which job to load by setting DEMO_STEP_ONE_PREGENERATED_FOLDER to the job’s unique identifier.
# One pregenerated job is available by default and can be used immediately: e84c79a9-48e2-407b-8d27-2a0e900473de

DEMO_STEP_ONE_USE_PREGENERATED=false
DEMO_STEP_ONE_PREGENERATED_FOLDER=e84c79a9-48e2-407b-8d27-2a0e900473de

## DEMO MUSIC

# Music generation during the demo can be enabled or disabled using the DEMO_STEP_ONE_GENERATE_MUSIC variable.
# Set the variable to true to enable music generation.
# Set it to false to disable it.

DEMO_STEP_ONE_GENERATE_MUSIC=false
